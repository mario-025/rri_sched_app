# =====================================================
# Flask Environment Configuration
# =====================================================

# Flask Environment Mode
# Set to 'development' untuk show error details
# Set to 'production' untuk hide error details (default)
FLASK_ENV=production

# Flask App Name
FLASK_APP=run.py

# Flask Server Configuration
# HOST - server address (default: 127.0.0.1 = localhost only)
#        ganti dengan 0.0.0.0 untuk accessible dari network lain
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Application timezone for scheduled reminders
APP_TIMEZONE=Asia/Makassar

# =====================================================
# Database Configuration
# =====================================================
# Untuk Docker Compose: gunakan "mysql" sebagai host
# Untuk Local Development: gunakan "localhost"
DB_HOST=mysql
DB_PORT=3306
DB_NAME=rritmb
DB_USER=appuser
DB_PASSWORD=apppassword
DB_ROOT_PASSWORD=root

# Legacy format (untuk backward compatibility)
DATABASE_HOST=localhost
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=rritmb

# Secret Key untuk session
# ⚠️ CHANGE THIS IN PRODUCTION ⚠️
SECRET_KEY=your-super-secret-key-change-this

# Session Configuration
SESSION_COOKIE_SECURE=False  # Set True untuk HTTPS only (production)
SESSION_COOKIE_HTTPONLY=True

# Telegram bot configuration
TELEGRAM_BOT_ENABLED=True
TELEGRAM_BOT_TOKEN=
APP_BASE_URL=http://127.0.0.1:5000
TELEGRAM_NOTIFIER_INTERVAL=30
